# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# Anthropic API key for the Claude tool-use agent loop.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model for the agent loop (tool-use capable).
AGENT_MODEL=claude-sonnet-4-5

# Set to 1 to force deterministic replay mode (no live API calls needed for the demo).
REPLAY_ONLY=0
